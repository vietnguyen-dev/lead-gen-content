{
  "name": "@vietnguyen-dev/lead-gen-content",
  "version": "1.0.0",
  "description": "Reusable content templates and types for lead generation websites.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-template": {
      "types": "./dist/property-wholesaling/test-template/index.d.ts",
      "import": "./dist/property-wholesaling/test-template/index.js"
    },
    "./test-template/buymyhousepdx.com": {
      "types": "./dist/property-wholesaling/test-template/buymyhousepdx.com/index.d.ts",
      "import": "./dist/property-wholesaling/test-template/buymyhousepdx.com/index.js"
    },
    "./test-template/portlandpropertybuyers.com": {
      "types": "./dist/property-wholesaling/test-template/portlandpropertybuyers.com/index.d.ts",
      "import": "./dist/property-wholesaling/test-template/portlandpropertybuyers.com/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "lead-generation",
    "content",
    "templates"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
